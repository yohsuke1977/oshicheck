{
  "manifest_version": 3,
  "name": "推し通知 - ライバー配信アラート",
  "version": "0.1.0",
  "description": "推しのライバーがYouTube・Twitchなど複数プラットフォームで配信開始したらまとめて通知",
  "action": {
    "default_popup": "popup.html",
    "default_title": "oshicheck"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "https://oshicheck.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "options_page": "options.html"
}
