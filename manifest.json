{
  "manifest_version": 3,
  "name": "推し通知 - VTuber/ライバーの配信をまとめて通知",
  "version": "0.1.4",
  "description": "YouTube Live・Twitch・SHOWROOM・ツイキャス・ふわっちの配信開始を、推しごとにまとめて通知。VTuberもライバーも見逃さない無料の配信通知拡張。",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "推し通知 - ライバー配信アラート",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],
  "host_permissions": [
    "https://oshicheck.vercel.app/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://firestore.googleapis.com/*"
  ],
  "options_page": "options.html"
}
